<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFramework>net8.0</TargetFramework>
		<LangVersion>latest</LangVersion>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
		<Nullable>enable</Nullable>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>

		<PackageId>Reprimand</PackageId>
		<Version>0.1.0</Version>
		<Authors>AtBelshftl</Authors>
		<Description>a utility library for Celeste mods</Description>
		<Copyright>Copyright (c) 2026 belshftl</Copyright>
		<PackageLicenseExpression>LGPL-3.0-only WITH AdditionRef-LGPLv3-Celeste-Target-Platform-Exception</PackageLicenseExpression>
		<RepositoryUrl>https://github.com/belshftl/Reprimand</RepositoryUrl>
		<RepositoryType>git</RepositoryType>

		<CelestePrefix Condition="'$(CelestePrefix)' == '' And Exists('../../../Celeste.dll')">../../..</CelestePrefix>
		<CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
		<RefCopyBlacklist>;MonoMod.Utils;MonoMod.Backports;System.Diagnostics.DiagnosticSource;MonoMod.Patcher;Mono.Cecil;Mono.Cecil.Mdb;Mono.Cecil.Pdb;</RefCopyBlacklist>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="MonoMod.RuntimeDetour" Version="25.3.1" PrivateAssets="all" ExcludeAssets="runtime" />
		<PackageReference Include="MonoMod.Patcher" Version="25.0.0-prerelease.2" Private="false" />
		<PackageReference Include="CelesteAnalyzer" Version="*" Private="false" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="CelesteMod.Publicizer" Version="*" CelesteAssembly="$(CelestePrefix)/Celeste.dll" />
		<Reference Include="$(CelestePrefix)/MMHOOK_Celeste.dll" Private="false" />
		<Reference Include="$(CelestePrefix)/FNA.dll" Private="false" />
	</ItemGroup>

	<Target Name="CopyFiles" AfterTargets="Build">
		<ItemGroup>
			<RefsToCopy Include="@(ReferenceCopyLocalPaths)" />
			<RefsToCopy Remove="@(RefsToCopy)" Condition="$([System.String]::Copy('$(RefCopyBlacklist)').Contains(';%(RefsToCopy.Filename);'))" />
		</ItemGroup>
		<Copy SourceFiles="$(OutputPath)/$(AssemblyName).dll" DestinationFolder="../Bin" />
		<Copy SourceFiles="$(OutputPath)/$(AssemblyName).pdb" DestinationFolder="../Bin" />
		<Copy SourceFiles="@(RefsToCopy)" DestinationFolder="../Bin" SkipUnchangedFiles="true" />
	</Target>
</Project>

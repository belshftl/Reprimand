root = true

[*.cs]
indent_style = tab
indent_size = tab
tab_width = 8

# i'm sorry i don't wanna make them long it just turns out like that
max_line_length = 190
resharper_max_line_length = 190

# indent/newline/ws
csharp_indent_braces = false
csharp_indent_switch_labels = false
csharp_new_line_before_catch = false
csharp_new_line_before_else = false
csharp_new_line_before_finally = false
csharp_new_line_before_open_brace = never
csharp_preserve_single_line_blocks = true
dotnet_separate_import_directive_groups = false

# PascalCase for public/internal/protected/protected internal
dotnet_naming_rule.public_internal_members_pascal.severity = suggestion
dotnet_naming_rule.public_internal_members_pascal.symbols = public_internal_members
dotnet_naming_rule.public_internal_members_pascal.style = pascal_case

dotnet_naming_symbols.public_internal_members.applicable_kinds = method, property, field, event
dotnet_naming_symbols.public_internal_members.applicable_accessibilities = public, internal, protected, protected_internal
dotnet_naming_symbols.public_internal_members.required_modifiers =

dotnet_naming_style.pascal_case.capitalization = pascal_case

# camelCase for private/private protected
dotnet_naming_rule.private_members_camel.severity = suggestion
dotnet_naming_rule.private_members_camel.symbols = private_members
dotnet_naming_rule.private_members_camel.style = camel_case

dotnet_naming_symbols.private_members.applicable_kinds = method, property, field, event
dotnet_naming_symbols.private_members.applicable_accessibilities = private, private_protected
dotnet_naming_symbols.private_members.required_modifiers =

dotnet_naming_style.camel_case.capitalization = camel_case

# modifier order
csharp_preferred_modifier_order = public, internal, private, protected, file, new, required, static, override, async, readonly, sealed, extern, virtual, volatile, unsafe, abstract:suggestion

# var/new() style
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_elsewhere = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_implicit_object_creation_when_type_is_apparent = true:suggestion

# shut up collection expression
dotnet_style_prefer_collection_expression = never:none

# don't align comments
csharp_int_align_comments = false

# method wrap style
resharper_csharp_wrap_parameters_style = chop_if_long
resharper_csharp_wrap_before_declaration_rpar = true
resharper_csharp_wrap_after_declaration_lpar = true

# primary ctor wrap style
resharper_csharp_wrap_primary_constructor_parameters_style = chop_if_long
resharper_csharp_wrap_before_primary_constructor_declaration_rpar = true
resharper_csharp_wrap_after_primary_constructor_declaration_lpar = true

# call wrap style
resharper_csharp_wrap_arguments_style = chop_if_long
resharper_csharp_wrap_before_invocation_rpar = true
resharper_csharp_wrap_after_invocation_lpar = true

# ternary op wrap style
resharper_csharp_wrap_ternary_expr_style = chop_if_long
resharper_csharp_wrap_before_ternary_opsigns = true

# expression body if possible
resharper_local_function_body = expression_body
resharper_method_or_operator_body = expression_body

# idk i let rider make the rest
resharper_align_multiline_binary_expressions_chain = false
resharper_align_multiline_statement_conditions = false
resharper_arguments_skip_single = true
resharper_blank_lines_after_block_statements = 0
resharper_blank_lines_around_auto_property = 0
resharper_blank_lines_around_local_method = 0
resharper_blank_lines_around_property = 0
resharper_blank_lines_around_single_line_type = 0
resharper_braces_for_fixed = required_for_multiline
resharper_braces_for_lock = required_for_multiline
resharper_braces_for_using = required_for_multiline
resharper_braces_for_while = required_for_multiline
resharper_cpp_align_multiline_argument = false
resharper_cpp_indent_style = tab
resharper_cpp_other_braces = end_of_line
resharper_csharp_allow_comment_after_lbrace = true
resharper_csharp_blank_lines_around_field = 0
resharper_csharp_blank_lines_around_invocable = 0
resharper_csharp_indent_style = tab
resharper_csharp_insert_final_newline = true
resharper_csharp_int_align_comments = false
resharper_csharp_other_braces = end_of_line
resharper_csharp_remove_blank_lines_near_braces_in_declarations = false
resharper_indent_braces_inside_statement_conditions = false
resharper_indent_nested_foreach_stmt = true
resharper_instance_members_qualify_declared_in =
resharper_new_line_before_else = false
resharper_new_line_before_while = false
resharper_outdent_statement_labels = true
resharper_parentheses_redundancy_style = remove
resharper_place_accessorholder_attribute_on_same_line = false
resharper_place_accessor_attribute_on_same_line = false
resharper_place_expr_accessor_on_single_line = true
resharper_place_expr_method_on_single_line = true
resharper_place_expr_property_on_single_line = true
resharper_place_simple_embedded_statement_on_same_line = false
resharper_place_simple_initializer_on_single_line = false
resharper_place_simple_list_pattern_on_single_line = false
resharper_simple_block_style = line_break
resharper_simple_embedded_statement_style = line_break
resharper_space_within_empty_braces = false
resharper_toplevel_function_declaration_return_type_style = on_single_line
resharper_toplevel_function_definition_return_type_style = line_break
